{
  "name": "hopsworks-managed",
  "version": "0.1.0",
  "private": true,
  "description": "Hopsworks managed clusters - Auth0 SDK v3 authentication",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:regression": "vitest run tests/regression",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.integration.config.ts",
    "test:resilience": "npx ts-node scripts/test-resilience.ts",
    "check:opencost-namespaces": "npx ts-node --project scripts/tsconfig.json scripts/check-opencost-namespaces.ts"
  },
  "dependencies": {
    "@auth0/nextjs-auth0": "^3.8.0",
    "@kubernetes/client-node": "^0.20.0",
    "@supabase/supabase-js": "^2.52.0",
    "@types/micro": "^7.3.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "micro": "^10.0.1",
    "next": "^15.4.8",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.289.0",
    "posthog-node": "^5.11.2",
    "radix-ui": "^1.4.3",
    "rate-limiter-flexible": "^7.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.1.0",
    "resend": "^4.7.0",
    "sonner": "^2.0.7",
    "stripe": "^18.3.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20.19.12",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.2.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8",
    "eslint-config-next": "^15.4.2",
    "postcss": "^8",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.15"
  }
}
